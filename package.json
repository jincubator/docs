{
  "name": "docs",
  "private": true,
  "version": "0.0.0",
  "packageManager": "bun@1.3.6",
  "type": "module",
  "scripts": {
    "dev": "vocs dev",
    "vocsbuild": "vocs build && node scripts/validate-site.mjs",
    "validate": "node scripts/validate-site.mjs",
    "validate:external": "node scripts/validate-site.mjs --external",
    "test": "node scripts/test-validate-site.mjs",
    "preview": "vocs preview",
    "predeploy": "vocs build",
    "sitedeploy": "cp docs/dist/index.html docs/dist/404.html && gh-pages -d docs/dist --nojekyll --cname www.jincubator.com"
  },
  "dependencies": {
    "baseline-browser-mapping": "^2.10.34",
    "caniuse-lite": "^1.0.30001797",
    "pdfjs-dist": "^5.3.93",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-medium-image-zoom": "^5.3.0",
    "react-pdf": "^10.0.1",
    "rehype-mathjax": "^7.1.0",
    "remark-math": "^6.0.0",
    "unist-util-visit": "^5.0.0",
    "vocs": "1.0.13"
  },
  "devDependencies": {
    "@types/react": "19.1.8",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-mdx": "^3.6.2",
    "eslint-plugin-mdx": "^3.6.2",
    "eslint-plugin-react": "^7.37.5",
    "gh-pages": "^6.3.0",
    "mermaid": "^11.12.0",
    "prettier": "^3.6.2",
    "remark-mermaidjs": "^7.0.0",
    "typescript": "5.8.3",
    "vitepress-plugin-mermaid": "^2.0.17"
  },
  "patchedDependencies": {
    "vocs@1.0.13": "patches/vocs@1.0.13.patch"
  }
}
